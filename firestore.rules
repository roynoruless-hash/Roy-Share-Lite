rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /telegram_broadcasts/{broadcastId} {
      allow read, write: if true;
    }
    match /settings/{settingId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
