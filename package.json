{
  "name": "react-example",
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/generate-build-info.js && tsx server.ts",
    "build": "node scripts/generate-build-info.js && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "audit:sos": "tsx scripts/audit-sos-race-conditions.ts"
  },
  "dependencies": {
    "@google/genai": "*",
    "canvas-confetti": "^1.9.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase": "^10.7.1",
    "firebase-admin": "^12.0.0",
    "framer-motion": "^10.18.0",
    "googleapis": "^130.0.0",
    "html-to-image": "^1.11.11",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.303.0",
    "motion": "^12.42.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "sanitize-html": "^2.11.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/canvas-confetti": "^1.6.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/sanitize-html": "^2.9.5",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.19.11",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4",
    "vite": "^5.0.8"
  }
}
