{
  "entities": {
    "admin": {
      "title": "Admin",
      "description": "Administrator user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["email", "role", "active"]
    },
    "transaction": {
      "title": "Transaction",
      "description": "User earnings/withdrawal transaction record",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "telegramUsername": { "type": "string" },
        "amount": { "type": "number" },
        "creditDebit": { "type": "string", "enum": ["Credit", "Debit"] },
        "source": { "type": "string" },
        "description": { "type": "string" },
        "eventName": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" },
        "adminNotes": { "type": "string" }
      },
      "required": ["userId", "amount", "creditDebit", "source", "description", "createdAt", "status"]
    },
    "referral": {
      "title": "Referral",
      "description": "Referral linking and commission tracking record",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "referredUsername": { "type": "string" },
        "referredFirstName": { "type": "string" },
        "joinDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "pendingCommission": { "type": "number" },
        "approvedCommission": { "type": "number" },
        "totalCommission": { "type": "number" }
      },
      "required": [
        "referrerId",
        "referredUserId",
        "joinDate",
        "status",
        "pendingCommission",
        "approvedCommission",
        "totalCommission"
      ]
    },
    "telegram_broadcast": {
      "title": "Telegram Broadcast",
      "description": "Record for Telegram Broadcast posts and scheduled tasks",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "language": { "type": "string" },
        "tone": { "type": "string" },
        "length": { "type": "string" },
        "imageUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "buttons": { "type": "array" },
        "status": { "type": "string", "enum": ["Draft", "Scheduled", "Sent", "Failed"] },
        "scheduledAt": { "type": "string" },
        "createdTime": { "type": "string" },
        "createdBy": { "type": "string" },
        "sentTime": { "type": "string" },
        "totalClicks": { "type": "number" },
        "miniAppOpens": { "type": "number" },
        "origin": { "type": "string" }
      },
      "required": ["message", "language", "tone", "length", "buttons", "status", "createdTime", "createdBy"]
    },
    "gift": {
      "title": "Gift",
      "description": "A reward gift item that users can claim",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Paused"] },
        "totalCodes": { "type": "number" },
        "claimedCodes": { "type": "number" },
        "remainingCodes": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "status", "totalCodes", "claimedCodes", "remainingCodes", "createdAt"]
    },
    "gift_code": {
      "title": "Gift Code",
      "description": "A single code for a reward gift",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "claimed": { "type": "boolean" },
        "claimedBy": { "type": "string" },
        "claimedAt": { "type": "string" }
      },
      "required": ["code", "claimed"]
    },
    "gift_claim": {
      "title": "Gift Claim",
      "description": "Record of a claim made by a user for a gift reward",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "telegramId": { "type": "string" },
        "giftId": { "type": "string" },
        "giftName": { "type": "string" },
        "claimedCode": { "type": "string" },
        "claimedAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["userId", "username", "telegramId", "giftId", "giftName", "claimedCode", "claimedAt", "status"]
    },
    "upi_giveaway": {
      "title": "UPI Giveaway",
      "description": "UPI Giveaway campaign created by admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "description": { "type": "string" },
        "totalBudget": { "type": "number" },
        "totalWinners": { "type": "number" },
        "minReward": { "type": "number" },
        "maxReward": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Live", "Paused", "Ended"] },
        "entryRules": { "type": "object" },
        "createdAt": { "type": "string" },
        "winnersDrawn": { "type": "boolean" }
      },
      "required": ["title", "bannerUrl", "totalBudget", "totalWinners", "minReward", "maxReward", "startDate", "endDate", "status", "entryRules", "createdAt"]
    },
    "upi_giveaway_entry": {
      "title": "UPI Giveaway Entry",
      "description": "User entry for a UPI Giveaway campaign",
      "type": "object",
      "properties": {
        "giveawayId": { "type": "string" },
        "telegramId": { "type": "string" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "upiId": { "type": "string" },
        "qrUrl": { "type": "string" },
        "qrPath": { "type": "string" },
        "entryTime": { "type": "string" },
        "status": { "type": "string" },
        "rewardAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "paidAt": { "type": "string" }
      },
      "required": ["giveawayId", "telegramId", "entryTime", "status"]
    },
    "gplinks_task": {
      "title": "Shortener Task",
      "description": "Universal Shortener Task campaign created by admin",
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "title": { "type": "string" },
        "shortenerUrl": { "type": "string" },
        "gpLinksUrl": { "type": "string" },
        "cpmAmount": { "type": "number" },
        "rewardPerView": { "type": "number" },
        "totalViewsLimit": { "type": "number" },
        "remainingViews": { "type": "number" },
        "completedViews": { "type": "number" },
        "timerDuration": { "type": "number" },
        "countryTarget": { "type": "string" },
        "deviceTarget": { "type": "string" },
        "expiryDate": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["provider", "title", "shortenerUrl", "cpmAmount", "rewardPerView", "totalViewsLimit", "remainingViews", "completedViews", "timerDuration", "status", "createdAt"]
    },
    "gplinks_task_completion": {
      "title": "GP Links Task Completion",
      "description": "GP Links task start/completion record for user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "status": { "type": "string" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "rewardAmount": { "type": "number" }
      },
      "required": ["userId", "taskId", "status", "startedAt"]
    },
    "adsgram_setting": {
      "title": "Adsgram Setting",
      "description": "Configuration for Adsgram Integration",
      "type": "object",
      "properties": {
        "adsgramAppId": { "type": "string" },
        "adsgramBlockId": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["adsgramAppId", "adsgramBlockId", "updatedAt"]
    },
    "adsgram_reward": {
      "title": "Adsgram Reward",
      "description": "Reward history log for Adsgram callbacks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string" },
        "method": { "type": "string" },
        "ip": { "type": "string" },
        "params": { "type": "object" },
        "status": { "type": "string" },
        "rewardAmount": { "type": "number" },
        "error": { "type": "string" },
        "adEventId": { "type": "string" }
      },
      "required": ["userId", "timestamp", "status", "rewardAmount"]
    }
  },
  "firestore": {
    "/settings/adsgram": {
      "schema": "adsgram_setting",
      "description": "Settings for Adsgram integration"
    },
    "/adsgram_rewards/{rewardId}": {
      "schema": "adsgram_reward",
      "description": "Collection tracking user rewards from Adsgram callbacks"
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Admins collection"
    },
    "/gplinks_tasks/{taskId}": {
      "schema": "gplinks_task",
      "description": "Collection of universal shortener tasks"
    },
    "/gplinks_task_completions/{completionId}": {
      "schema": "gplinks_task_completion",
      "description": "Collection of shortener task completions"
    },
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Earnings and deduction transactions collection"
    },
    "/referrals/{referredUserId}": {
      "schema": "referral",
      "description": "Collection tracking user referrals and potential/approved commission"
    },
    "/telegram_broadcasts/{broadcastId}": {
      "schema": "telegram_broadcast",
      "description": "Collection tracking Telegram Broadcast posts, scheduled tasks, and interactive clicks"
    },
    "/gifts/{giftId}": {
      "schema": "gift",
      "description": "Collection of reward gifts"
    },
    "/gifts/{giftId}/codes/{codeId}": {
      "schema": "gift_code",
      "description": "Subcollection of unique codes for a specific gift"
    },
    "/gift_claims/{claimId}": {
      "schema": "gift_claim",
      "description": "Collection of user gift claims history"
    },
    "/upi_giveaways/{giveawayId}": {
      "schema": "upi_giveaway",
      "description": "Collection of UPI giveaways"
    },
    "/upi_giveaway_entries/{entryId}": {
      "schema": "upi_giveaway_entry",
      "description": "Collection of UPI giveaway entries"
    }
  }
}
